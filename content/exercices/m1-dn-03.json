        "label": "CN=Lucas Faure,OU=Equipe,DC=it.entreprise.lan"
      },
      {
        "value": "ko2",
        "label": "CN=Lucas Faure,OU=Equipe,DC=lan,DC=entreprise,DC=it"
      },
      {
        "value": "ko3",
        "label": "OU=Equipe,CN=Lucas Faure,DC=entreprise.lan,DC=it"
      },
      {
        "value": "ok",
        "label": "CN=Lucas Faure,OU=Equipe,DC=it,DC=entreprise,DC=lan"
      }
    ]
  },
  "solution": {
